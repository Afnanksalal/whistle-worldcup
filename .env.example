# TxLINE — use a real token when you have one. Placeholder txl_… boots on free TheSportsDB schedule.
TXLINE_NETWORK=devnet
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=txl_replace_with_real_token

ADMIN_API_KEY=replace_with_a_random_admin_key_at_least_16_chars

SOLANA_KEYPAIR_PATH=./wallet.json
SOLANA_RPC_URL=https://api.devnet.solana.com
WHISTLE_PROGRAM_ID=
WHISTLE_AUTHORITY_KEY=
STAKE_ASSET=units
SETTLEMENT_RAIL=ledger
ENABLE_ONCHAIN_SETTLEMENT=false
USDC_MINT=
PLATFORM_FEE_BPS=250

PORT=4000
NODE_ENV=development
API_CORS_ORIGIN=http://localhost:3000
REQUIRE_WALLET_AUTH=false
KEEP_SETTLE_ENABLED=true
LOG_LEVEL=debug
RATE_LIMIT_PER_MIN=300

# Optional — enables LLM "AI desk note" on match insights (engine works without)
# GROQ_API_KEY=
# The same server-only key may enrich forecast notes; it never changes probabilities.
# GROQ_MODEL=openai/gpt-oss-20b
# FORECAST_CACHE_TTL_MS=300000
# FORECAST_LIVE_CACHE_TTL_MS=30000
# FORECAST_AI_TIMEOUT_MS=6000
# FORECAST_HISTORY_REQUESTS_PER_MIN=6
# FORECAST_HISTORY_TIMEOUT_MS=5000
# TSDB_STATS_REQUESTS_PER_MIN=18
# TSDB_STATS_TIMEOUT_MS=6000
# OPENAI_API_KEY=
# GEMINI_API_KEY=

NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
