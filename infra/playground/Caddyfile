{
	auto_https off
	default_sni {$VPS_PUBLIC_IP}
}

(whistle_proxy) {
	header {
		-X-Powered-By
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Content-Security-Policy "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; img-src 'self' data: https:; connect-src 'self' https: wss: ws:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'"
	}

	@private_index path /admin* /api/* /ws
	header @private_index X-Robots-Tag "noindex, nofollow, noarchive"

	handle /api/* {
		reverse_proxy api:4000
	}

	handle /ws {
		reverse_proxy api:4000
	}

	handle {
		reverse_proxy web:3000
	}
}

# Public TLS (needs SG 9444). Cert on this box is currently expired — prefer tunnel.
https://{$VPS_PUBLIC_IP}:{$WHISTLE_TLS_PORT}, :{$WHISTLE_TLS_PORT} {
	encode zstd gzip
	tls /etc/letsencrypt/live/{$VPS_PUBLIC_IP}/fullchain.pem /etc/letsencrypt/live/{$VPS_PUBLIC_IP}/privkey.pem
	import whistle_proxy
}

# Local HTTP for cloudflared quick tunnel (no inbound SG needed)
:8088 {
	encode zstd gzip
	import whistle_proxy
}
