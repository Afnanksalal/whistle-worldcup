VPS_PUBLIC_IP=18.61.174.6
WHISTLE_TLS_PORT=9444
TXLINE_API_TOKEN=txl_replace_with_real_token
TXLINE_GUEST_JWT=
TXLINE_NETWORK=devnet
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
ADMIN_API_KEY=replace_with_a_random_admin_key_at_least_16_chars
API_CORS_ORIGIN=same-origin
REQUIRE_WALLET_AUTH=true
SOLANA_RPC_URL=https://api.devnet.solana.com
WHISTLE_PROGRAM_ID=
# Default playground rail: play-unit ledger (no USDC).
STAKE_ASSET=units
SETTLEMENT_RAIL=ledger
ENABLE_ONCHAIN_SETTLEMENT=false
# Enable after the program is deployed and initialized. COMPOSE_FILE makes the
# authority key available to the API as a read-only file.
# COMPOSE_FILE=docker-compose.yml:docker-compose.onchain.yml
# STAKE_ASSET=USDC
# SETTLEMENT_RAIL=onchain
# ENABLE_ONCHAIN_SETTLEMENT=true
# WHISTLE_AUTHORITY_FILE=/opt/whistle/secrets/whistle-authority.json
# USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# PLATFORM_FEE_BPS=250
LOG_LEVEL=info
RATE_LIMIT_PER_MIN=120
# Optional LLM for grounded match notes. Deterministic forecasts work without it.
# GROQ_API_KEY=
# GROQ_MODEL=openai/gpt-oss-20b
# FORECAST_CACHE_TTL_MS=300000
# FORECAST_LIVE_CACHE_TTL_MS=30000
# FORECAST_AI_TIMEOUT_MS=6000
# FORECAST_HISTORY_REQUESTS_PER_MIN=6
# FORECAST_HISTORY_TIMEOUT_MS=5000
# TSDB_STATS_REQUESTS_PER_MIN=18
# TSDB_STATS_TIMEOUT_MS=6000
# OPENAI_API_KEY=
# GEMINI_API_KEY=
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_SITE_URL=https://your-public-origin.example
# Optional. When unset, the tunnel profile uses a temporary trycloudflare URL.
# CLOUDFLARE_TUNNEL_TOKEN=
